{
  "family": "dis-v7",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "2048",
  "memory": "4096",
  "executionRoleArn": "arn:aws:iam::855250841305:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "855250841305.dkr.ecr.ap-south-1.amazonaws.com/dis-v7-backend:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 8000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "USE_SAGEMAKER",        "value": "false" },
        { "name": "MLFLOW_TRACKING_URI",  "value": "http://localhost:5001" }
      ],
      "secrets": [
        {
          "name": "GROQ_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-1:855250841305:secret:dis-v7/groq-api-key"
        }
      ],
      "mountPoints": [
        { "sourceVolume": "embeddings", "containerPath": "/app/embeddings_store" },
        { "sourceVolume": "evaldb",     "containerPath": "/app/eval_log.db" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/dis-v7/backend",
          "awslogs-region":        "ap-south-1",
          "awslogs-stream-prefix": "backend"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:8000/health || exit 1"],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 60
      }
    },
    {
      "name": "frontend",
      "image": "855250841305.dkr.ecr.ap-south-1.amazonaws.com/dis-v7-frontend:latest",
      "essential": true,
      "portMappings": [
        { "containerPort": 5000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "BACKEND_URL", "value": "http://localhost:8000" }
      ],
      "dependsOn": [
        { "containerName": "backend", "condition": "HEALTHY" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/dis-v7/frontend",
          "awslogs-region":        "ap-south-1",
          "awslogs-stream-prefix": "frontend"
        }
      }
    },
    {
      "name": "mlflow",
      "image": "ghcr.io/mlflow/mlflow:v2.13.0",
      "essential": false,
      "portMappings": [
        { "containerPort": 5001, "protocol": "tcp" }
      ],
      "command": [
        "mlflow", "server",
        "--host", "0.0.0.0",
        "--port", "5001",
        "--backend-store-uri", "sqlite:///mlflow/mlflow.db",
        "--default-artifact-root", "/mlflow/artifacts"
      ],
      "mountPoints": [
        { "sourceVolume": "mlflow", "containerPath": "/mlflow" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/dis-v7/mlflow",
          "awslogs-region":        "ap-south-1",
          "awslogs-stream-prefix": "mlflow"
        }
      }
    },
    {
      "name": "grafana",
      "image": "grafana/grafana:10.4.0",
      "essential": false,
      "portMappings": [
        { "containerPort": 3000, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "GF_SECURITY_ADMIN_PASSWORD", "value": "admin" },
        { "name": "GF_USERS_ALLOW_SIGN_UP",     "value": "false" }
      ],
      "mountPoints": [
        { "sourceVolume": "grafana", "containerPath": "/var/lib/grafana" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/dis-v7/grafana",
          "awslogs-region":        "ap-south-1",
          "awslogs-stream-prefix": "grafana"
        }
      }
    }
  ],
  "volumes": [
    { "name": "embeddings", "host": {} },
    { "name": "evaldb",     "host": {} },
    { "name": "mlflow",     "host": {} },
    { "name": "grafana",    "host": {} }
  ]
}